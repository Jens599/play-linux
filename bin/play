#!/usr/bin/env bash
set -euo pipefail

PLAY_SOURCE=${BASH_SOURCE[0]}
while [[ -L $PLAY_SOURCE ]]; do
  PLAY_DIR=$(cd -P "$(dirname "$PLAY_SOURCE")" && pwd)
  PLAY_SOURCE=$(readlink "$PLAY_SOURCE")
  [[ $PLAY_SOURCE != /* ]] && PLAY_SOURCE=$PLAY_DIR/$PLAY_SOURCE
done
PLAY_ROOT=$(cd -P "$(dirname "$PLAY_SOURCE")/.." && pwd)
# shellcheck source=../lib/config.sh
# shellcheck disable=SC1091
source "$PLAY_ROOT/lib/config.sh"
# shellcheck disable=SC1091
source "$PLAY_ROOT/lib/utils.sh"
# shellcheck disable=SC1091
source "$PLAY_ROOT/lib/args.sh"
# shellcheck disable=SC1091
source "$PLAY_ROOT/lib/search.sh"
# shellcheck disable=SC1091
source "$PLAY_ROOT/lib/picker.sh"
# shellcheck disable=SC1091
source "$PLAY_ROOT/lib/history.sh"
# shellcheck disable=SC1091
source "$PLAY_ROOT/lib/clipboard.sh"
# shellcheck disable=SC1091
source "$PLAY_ROOT/lib/doctor.sh"
# shellcheck disable=SC1091
source "$PLAY_ROOT/lib/player.sh"

PLAY_CLEANUP_FILES=()
PLAY_CLEANUP_PIDS=()
PLAY_ORIGINAL_ARGS=("$@")
trap play_interrupt INT TERM

play_usage() {
  cat <<'EOF'
usage: play [options] [url-or-query]

Core:
  play URL                         Play a direct URL
  play -s "query"                  Search YouTube and play selection
  play --home                      Search YouTube home feed
  play --history | --last          Replay history

Options:
  -s, --search                     Treat input as search query
  -p, --playlist                   Playlist search
  -t, --type video|playlist|channel
  --channel-playlists              Pick playlists from a channel URL/search
  --playlist-results N             Initial channel playlist results count
  --first                          Select first result without picker
  --clipboard                      Read URL from clipboard
  --copy-url                       Copy resolved URL instead of playing
  --open                           Open resolved URL with xdg-open
  --select-only                    Print selected item as TSV
  --dry-run                        Print command without starting player
  --pass-thru                      With --dry-run, print machine-readable fields
  --debug                          Write a debug log under state directory
  --debug-log PATH                 Write a debug log to PATH
  --reverse                        Reverse selected URL/order targets
  --clear-history                  Clear history
  --config                         Open config in $EDITOR
  --config-path                    Print config path
  --config-export PATH             Export config
  --config-import PATH             Import config
  --install-bash-completion        Install bash completion for this user
  --set KEY=VALUE                  Set a config value
  --get KEY                        Print a config value
  --doctor                         Show dependency/config diagnostics

Playback:
  --cookies PATH                   Use and persist cookie path
  --cookies-from-browser BROWSER   Use and persist browser cookies
  --size pip|small|medium|max      Window size preset
  -f, --format 480p|720p|1080p|best|audio
  --audio-only                     Add --no-video
  --background                     Start player in background
  --loop                           Loop playback
  --hwdec                          Enable hardware acceleration
  --reverse-playlist               Reverse videos inside playlist URLs
  --no-subtitles                   Omit subtitle preference
  --subtitle-language en,ja        Preferred subtitle language(s)
  --mpv-arg ARG                    Append custom mpv argument
EOF
}

play_option_hint() {
  case "$1" in
    -f|--format) printf '%s\n' 'Example: play -s "backlogs" -t channel --format 720p' ;;
    -t|--type) printf '%s\n' 'Example: play -s "backlogs" --type channel' ;;
    --playlist-results) printf '%s\n' 'Example: play --channel-playlists --playlist-results 25 URL' ;;
    --size|-sz) printf '%s\n' 'Example: play URL --size small' ;;
    --cookies|-c) printf '%s\n' 'Example: play URL --cookies ~/cookies.txt' ;;
    --cookies-from-browser) printf '%s\n' 'Example: play URL --cookies-from-browser firefox' ;;
    --subtitle-language) printf '%s\n' 'Example: play URL --subtitle-language en,ja' ;;
    --mpv-arg) printf '%s\n' 'Example: play URL --mpv-arg --speed=1.25' ;;
    --config-export) printf '%s\n' 'Example: play --config-export ./play.conf' ;;
    --config-import) printf '%s\n' 'Example: play --config-import ./play.conf' ;;
    --set) printf '%s\n' 'Example: play --set YTDL_FORMAT=720p' ;;
    --get) printf '%s\n' 'Example: play --get YTDL_FORMAT' ;;
    *) printf '%s\n' 'Run play --help to see valid options.' ;;
  esac
}

play_error() {
  printf 'Error: %s\n' "$1" >&2
}

play_hint() {
  printf 'Hint: %s\n' "$1" >&2
}

play_missing_option_value() {
  local option=$1 value_name=$2
  play_error "$option requires $value_name."
  play_hint "$(play_option_hint "$option")"
  printf 'Try: play --help\n' >&2
  exit 2
}

play_require_option_value() {
  local option=$1 value_name=$2 value=${3:-} allow_dash=${4:-false}
  if [[ -z $value ]]; then
    play_missing_option_value "$option" "$value_name"
  fi
  if [[ $allow_dash != true && $value == -* ]]; then
    play_missing_option_value "$option" "$value_name"
  fi
}

play_invalid_value() {
  local label=$1 value=$2 expected=$3 hint=${4:-}
  play_error "$label has invalid value: $value"
  play_hint "Expected: $expected"
  [[ -n $hint ]] && play_hint "$hint"
  exit 2
}

play_is_bool_value() {
  case "${1,,}" in
    true|t|yes|y|1|on|false|f|no|n|0|off) return 0 ;;
    *) return 1 ;;
  esac
}

play_is_none_or_auto_value() {
  play_is_none "$1" || play_is_auto_format "$1"
}

play_validate_effective_settings() {
  case "${SIZE_EFFECTIVE,,}" in
    pip|small|medium|max) ;;
    *) play_invalid_value 'size' "$SIZE_EFFECTIVE" 'pip, small, medium, or max' 'Example: play URL --size small' ;;
  esac

  case "${YTDL_FORMAT_EFFECTIVE,,}" in
    480p|720p|1080p|best|audio) ;;
    *) play_invalid_value 'format' "$YTDL_FORMAT_EFFECTIVE" '480p, 720p, 1080p, best, or audio' 'Example: play URL --format 720p' ;;
  esac

  local bool_name bool_value
  for bool_name in AUDIO_ONLY_EFFECTIVE BACKGROUND_EFFECTIVE LOOP_EFFECTIVE HARDWARE_ACCEL_EFFECTIVE REVERSE_PLAYLIST_EFFECTIVE NO_SUBTITLES_EFFECTIVE; do
    bool_value=${!bool_name}
    play_is_bool_value "$bool_value" || play_invalid_value "$bool_name" "$bool_value" 'true or false'
  done
  for bool_name in REMEMBER_PLAYBACK_SPEED YTDL_NO_DOWNLOAD_ARCHIVE; do
    bool_value=${!bool_name:-true}
    play_is_bool_value "$bool_value" || play_invalid_value "$bool_name" "$bool_value" 'true or false'
  done

  [[ ${MAX_RESULTS:-10} =~ ^[1-9][0-9]*$ ]] || play_invalid_value 'MAX_RESULTS' "${MAX_RESULTS:-}" 'a positive integer'
  [[ ${YTDL_MAX_FPS:-30} =~ ^[0-9]+$ ]] || play_is_none_or_auto_value "${YTDL_MAX_FPS:-30}" || play_invalid_value 'YTDL_MAX_FPS' "${YTDL_MAX_FPS:-}" 'a number, auto, or none'
  [[ ${YTDL_MAX_HEIGHT:-from_quality} =~ ^[0-9]+$ ]] || play_is_none_or_auto_value "${YTDL_MAX_HEIGHT:-from_quality}" || play_invalid_value 'YTDL_MAX_HEIGHT' "${YTDL_MAX_HEIGHT:-}" 'a number, from_quality, auto, or none'
}

play_apply_selected_rows() {
  local rows=$1 row
  local type title url duration source views count
  PLAY_TARGET_URLS=()
  PLAY_TARGET_TITLES=()
  PLAY_TARGET_TYPES=()

  while IFS= read -r row; do
    [[ -z $row ]] && continue
    IFS=$'\t' read -r type title url duration source views count <<<"$row"
    if ((${#PLAY_TARGET_URLS[@]} == 0)); then
      PLAY_HISTORY_TYPE=$type
      PLAY_HISTORY_TITLE=$title
      PLAY_TARGET_URL=$url
      PLAY_HISTORY_DURATION=$duration
      PLAY_HISTORY_SOURCE=$source
      PLAY_HISTORY_VIEWS=$views
      PLAY_HISTORY_COUNT=$count
    fi
    PLAY_TARGET_URLS+=("$url")
    PLAY_TARGET_TITLES+=("$title")
    PLAY_TARGET_TYPES+=("$type")
  done <<<"$rows"

  ((${#PLAY_TARGET_URLS[@]} > 0))
}

play_show_selected() {
  play_section 'Selected' >&2
  play_detail 'Title' "$PLAY_HISTORY_TITLE" >&2
  play_detail 'Type' "$PLAY_HISTORY_TYPE" >&2
  [[ -n ${PLAY_HISTORY_SOURCE:-} && ${PLAY_HISTORY_SOURCE:-} != NA ]] && play_detail 'Source' "$PLAY_HISTORY_SOURCE" >&2
  [[ -n ${PLAY_HISTORY_DURATION:-} && ${PLAY_HISTORY_DURATION:-} != NA ]] && play_detail 'Duration' "$PLAY_HISTORY_DURATION" >&2
  [[ -n ${PLAY_HISTORY_VIEWS:-} && ${PLAY_HISTORY_VIEWS:-} != NA ]] && play_detail 'Views' "$PLAY_HISTORY_VIEWS" >&2
  [[ -n ${PLAY_HISTORY_COUNT:-} && ${PLAY_HISTORY_COUNT:-} != NA ]] && play_detail 'Items' "$PLAY_HISTORY_COUNT" >&2
  play_detail 'URL' "$PLAY_TARGET_URL" >&2
  if ((${#PLAY_TARGET_URLS[@]} > 1)); then
    play_detail 'Count' "${#PLAY_TARGET_URLS[@]}" >&2
    local i item_title
    for i in "${!PLAY_TARGET_URLS[@]}"; do
      item_title=${PLAY_TARGET_TITLES[i]:-${PLAY_TARGET_URLS[i]}}
      printf '  %s %02d. %s\n' "$(play_color 90 'Item      ')" "$((i + 1))" "$item_title" >&2
    done
  fi
}

play_reverse_targets() {
  local i
  local reversed=()
  local reversed_titles=()
  local reversed_types=()
  for ((i = ${#PLAY_TARGET_URLS[@]} - 1; i >= 0; i--)); do reversed+=("${PLAY_TARGET_URLS[i]}"); done
  for ((i = ${#PLAY_TARGET_TITLES[@]} - 1; i >= 0; i--)); do reversed_titles+=("${PLAY_TARGET_TITLES[i]}"); done
  for ((i = ${#PLAY_TARGET_TYPES[@]} - 1; i >= 0; i--)); do reversed_types+=("${PLAY_TARGET_TYPES[i]}"); done
  PLAY_TARGET_URLS=("${reversed[@]}")
  PLAY_TARGET_TITLES=("${reversed_titles[@]}")
  PLAY_TARGET_TYPES=("${reversed_types[@]}")
  PLAY_TARGET_URL=${PLAY_TARGET_URLS[0]}
}

play_is_playlist_target() {
  local index=$1 target_url
  target_url=${PLAY_TARGET_URLS[$index]}
  [[ ${PLAY_TARGET_TYPES[$index]:-} == Playlist || $target_url == *'youtube.com/playlist?list='* || $target_url == *'&list='* || $target_url == *'?list='* ]]
}

play_expand_reversed_playlist_targets() {
  local i target_url target_title row title url args
  local expanded_urls=() expanded_titles=() expanded_types=() changed=false
  play_bool "${REVERSE_PLAYLIST_EFFECTIVE:-false}" || return 0
  play_has yt-dlp || return 0

  for i in "${!PLAY_TARGET_URLS[@]}"; do
    target_url=${PLAY_TARGET_URLS[i]}
    target_title=${PLAY_TARGET_TITLES[i]:-$target_url}
    if ! play_is_playlist_target "$i"; then
      expanded_urls+=("$target_url")
      expanded_titles+=("$target_title")
      expanded_types+=("${PLAY_TARGET_TYPES[i]:-Direct}")
      continue
    fi

    play_log step "Expanding reversed playlist: $target_title" >&2
    args=("$target_url" --flat-playlist --playlist-items 1- --playlist-reverse --print $'%(title)s\t%(webpage_url)s')
    [[ -n ${COOKIE_PATH_EFFECTIVE:-} ]] && args+=(--cookies "$COOKIE_PATH_EFFECTIVE")
    [[ -z ${COOKIE_PATH_EFFECTIVE:-} && -n ${COOKIE_BROWSER_EFFECTIVE:-} ]] && args+=(--cookies-from-browser "$COOKIE_BROWSER_EFFECTIVE")

    while IFS= read -r row; do
      IFS=$'\t' read -r title url <<<"$row"
      [[ -z $url || $url == NA ]] && continue
      expanded_urls+=("$url")
      expanded_titles+=("${title:-$url}")
      expanded_types+=(Video)
      changed=true
    done < <(yt-dlp "${args[@]}" 2>/dev/null)
  done

  if play_bool "$changed"; then
    PLAY_TARGET_URLS=("${expanded_urls[@]}")
    PLAY_TARGET_TITLES=("${expanded_titles[@]}")
    PLAY_TARGET_TYPES=("${expanded_types[@]}")
    PLAY_TARGET_URL=${PLAY_TARGET_URLS[0]}
    REVERSE_PLAYLIST_EFFECTIVE=false
  fi
}

play_select_exact_channel_row() {
  local rows=$1 query=$2 row type title url duration source views count match=
  while IFS= read -r row; do
    [[ -z $row ]] && continue
    IFS=$'\t' read -r type title url duration source views count <<<"$row"
    if [[ $type == Channel && ( ${title,,} == "${query,,}" || ${source,,} == "${query,,}" ) ]]; then
      if [[ -n $match ]]; then return 1; fi
      match=$row
    fi
  done <<<"$rows"
  [[ -n $match ]] || return 1
  printf '%s\n' "$match"
}

play_pick_channel_playlists() {
  local channel_url=$1 channel_title=$2 channel_source=${3:-$2}
  local tmp selected result_batch result_end more_cmd state_file

  tmp=$(mktemp)
  play_register_cleanup_file "$tmp"
  play_section 'Channel Playlists' >&2
  play_detail 'Channel' "$channel_title" >&2
  play_log step 'Fetching playlists.' >&2
  result_batch=${PLAYLIST_RESULTS_ARG:-${MAX_RESULTS:-10}}
  result_end=$result_batch
  play_search_channel_playlists "$channel_url" "$result_end" "$COOKIE_PATH_EFFECTIVE" "$COOKIE_BROWSER_EFFECTIVE" "$channel_source" >"$tmp"
  if [[ ! -s $tmp ]]; then play_unregister_cleanup_file "$tmp"; printf 'No playlists found.\n' >&2; rm -f "$tmp"; return 1; fi
  state_file=$(mktemp)
  play_register_cleanup_file "$state_file"
  printf '%s\n' "$result_end" >"$state_file"
  more_cmd=$(play_make_more_results_command channel "$tmp" "$state_file" "$result_batch" "$channel_url" "$channel_source")
  selected=$(play_pick_result 'Channel Playlists' "$tmp" true true "$more_cmd") || { play_unregister_cleanup_file "$tmp"; play_unregister_cleanup_file "$state_file"; rm -f "$tmp" "$state_file"; return 1; }
  play_unregister_cleanup_file "$state_file"
  rm -f "$state_file"
  play_unregister_cleanup_file "$tmp"
  rm -f "$tmp"
  play_apply_selected_rows "$selected"
}

play_make_more_results_command() {
  local mode=$1 input_file=$2 state_file=$3 batch=$4 query_or_url=$5 source=${6:-}
  local cmd_file
  cmd_file=$(mktemp)
  play_register_cleanup_file "$cmd_file"
  cat >"$cmd_file" <<EOF
#!/usr/bin/env bash
set -euo pipefail
source $(printf '%q' "$PLAY_ROOT/lib/config.sh")
source $(printf '%q' "$PLAY_ROOT/lib/utils.sh")
source $(printf '%q' "$PLAY_ROOT/lib/search.sh")
input_file=$(printf '%q' "$input_file")
state_file=$(printf '%q' "$state_file")
batch=$(printf '%q' "$batch")
mode=$(printf '%q' "$mode")
query_or_url=$(printf '%q' "$query_or_url")
source_label=$(printf '%q' "$source")
home=$(printf '%q' "${HOME_FEED:-false}")
playlist=$(printf '%q' "${PLAYLIST:-false}")
type=$(printf '%q' "${NORMALIZED_TYPE:-}")
cookie=$(printf '%q' "${COOKIE_PATH_EFFECTIVE:-}")
browser=$(printf '%q' "${COOKIE_BROWSER_EFFECTIVE:-}")
end=\$(<"\$state_file")
start=\$((end + 1))
end=\$((end + batch))
tmp=\$(mktemp)
trap 'rm -f "\$tmp"' EXIT
if [[ \$mode == channel ]]; then
  play_search_channel_playlists "\$query_or_url" "\$end" "\$cookie" "\$browser" "\$source_label" "\$start" >"\$tmp"
else
  play_search_youtube "\$query_or_url" "\$home" "\$playlist" "\$end" "\$cookie" "\$type" "\$browser" "\$start" >"\$tmp"
fi
if [[ -s \$tmp ]]; then
  cat "\$tmp" >>"\$input_file"
  printf '%s\n' "\$end" >"\$state_file"
fi
EOF
  chmod +x "$cmd_file"
  printf '%q\n' "$cmd_file"
}

play_install_bash_completion() {
  local completion_dir completion_file bashrc zshrc marker_begin marker_end zsh_marker_begin zsh_marker_end block_file tmp_bashrc tmp_zshrc
  completion_dir=${XDG_DATA_HOME:-$HOME/.local/share}/play
  completion_file=$completion_dir/completion.bash
  bashrc=$HOME/.bashrc
  zshrc=$HOME/.zshrc
  marker_begin='# >>> play bash completion >>>'
  marker_end='# <<< play bash completion <<<'
  zsh_marker_begin='# >>> play zsh completion >>>'
  zsh_marker_end='# <<< play zsh completion <<<'

  mkdir -p "$completion_dir"
  cat >"$completion_file" <<'EOF'
_play_complete() {
  local cur prev opts
  COMPREPLY=()
  cur=${COMP_WORDS[COMP_CWORD]}
  prev=${COMP_WORDS[COMP_CWORD-1]}

  case "$prev" in
    -t|--type)
      COMPREPLY=($(compgen -W 'video playlist channel' -- "$cur"))
      return
      ;;
    --size|-sz)
      COMPREPLY=($(compgen -W 'pip small medium max' -- "$cur"))
      return
      ;;
    -f|--format)
      COMPREPLY=($(compgen -W '480p 720p 1080p best audio' -- "$cur"))
      return
      ;;
    --cookies|--config-export|--config-import|--debug-log)
      COMPREPLY=($(compgen -f -- "$cur"))
      return
      ;;
    --cookies-from-browser)
      COMPREPLY=($(compgen -W 'firefox chrome chromium brave vivaldi edge opera' -- "$cur"))
      return
      ;;
    --playlist-results)
      COMPREPLY=($(compgen -W '10 20 30 50 100' -- "$cur"))
      return
      ;;
    --subtitle-language)
      COMPREPLY=($(compgen -W 'en ja es fr de ko zh ru pt it' -- "$cur"))
      return
      ;;
    --set)
      COMPREPLY=($(compgen -W 'PLAYER= MENU_PROVIDER= COOKIE_PATH= COOKIE_BROWSER= SIZE= YTDL_FORMAT= MAX_RESULTS= PLAY_COLOR= AUDIO_ONLY= BACKGROUND= LOOP= HARDWARE_ACCEL= REVERSE_PLAYLIST= NO_SUBTITLES= SUBTITLE_LANGUAGE= REMEMBER_PLAYBACK_SPEED= YTDL_VIDEO_SELECTOR= YTDL_VIDEO_CODEC_FILTER= YTDL_MAX_HEIGHT= YTDL_MAX_FPS= YTDL_AUDIO_SELECTOR= YTDL_FALLBACK_SELECTOR= YTDL_NO_DOWNLOAD_ARCHIVE= COMMAND_TERMINAL= COMMAND_GEOMETRY= COMMAND_AUTOFIT= COMMAND_NO_BORDER= COMMAND_ONTOP= COMMAND_HWDEC= COMMAND_SAVE_POSITION= COMMAND_WATCH_LATER_OPTIONS= COMMAND_PLAYER= COMMAND_PREPEND_ARGUMENT= COMMAND_REPLACE_ARGUMENT= COMMAND_APPEND_ARGUMENT= COMMAND_URL= COMMAND_BACKGROUND=' -- "$cur"))
      return
      ;;
  esac

  opts='--search -s --home --playlist -p --type -t --channel-playlists --channel-playlist --playlist-results --first -fi --clipboard --history --last --clear-history --dry-run --pass-thru --debug --debug-log --reverse --select-only --copy-url --open --cookies -c --cookies-from-browser --size -sz --format -f --audio-only -a --background -b --loop -l --hwdec -h --reverse-playlist -r --no-subtitles --subtitle-language --mpv-arg --config --config-path --config-export --config-import --install-bash-completion --set --get --doctor --help -help'
  if [[ $cur == -* ]]; then
    COMPREPLY=($(compgen -W "$opts" -- "$cur"))
  else
    COMPREPLY=($(compgen -f -- "$cur"))
  fi
}

complete -F _play_complete play
EOF

  block_file=$(mktemp)
  cat >"$block_file" <<EOF

$marker_begin
if [ -r "$completion_file" ]; then
  . "$completion_file"
fi
$marker_end
EOF

  if [[ ! -f $bashrc ]]; then
    : >"$bashrc"
  fi

  tmp_bashrc=$(mktemp)
  awk -v begin="$marker_begin" -v end="$marker_end" '
    $0 == begin { skip = 1; next }
    $0 == end { skip = 0; next }
    !skip { print }
  ' "$bashrc" >"$tmp_bashrc"
  mv "$tmp_bashrc" "$bashrc"

  tmp_bashrc=$(mktemp)
  awk -v block="$block_file" '
    !inserted && $0 ~ /^[[:space:]]*exec[[:space:]]+zsh([[:space:]]|$)/ {
      while ((getline line < block) > 0) print line
      close(block)
      inserted = 1
    }
    { print }
    END {
      if (!inserted) {
        while ((getline line < block) > 0) print line
        close(block)
      }
    }
  ' "$bashrc" >"$tmp_bashrc"
  mv "$tmp_bashrc" "$bashrc"
  rm -f "$block_file"

  if [[ -f $zshrc ]]; then
    block_file=$(mktemp)
    cat >"$block_file" <<EOF

$zsh_marker_begin
autoload -Uz bashcompinit
bashcompinit
if [ -r "$completion_file" ]; then
  . "$completion_file"
fi
$zsh_marker_end
EOF

    tmp_zshrc=$(mktemp)
    awk -v begin="$zsh_marker_begin" -v end="$zsh_marker_end" '
      $0 == begin { skip = 1; next }
      $0 == end { skip = 0; next }
      !skip { print }
    ' "$zshrc" >"$tmp_zshrc"
    mv "$tmp_zshrc" "$zshrc"

    cat "$block_file" >>"$zshrc"
    rm -f "$block_file"
    printf 'Updated zsh startup file: %s\n' "$zshrc"
  fi

  printf 'Installed bash completion: %s\n' "$completion_file"
  printf 'Updated bash startup file: %s\n' "$bashrc"
  printf 'Restart your shell, or run: source %q\n' "$completion_file"
}

SEARCH=false HOME_FEED=false PLAYLIST=false CHANNEL_PLAYLISTS=false FIRST=false CLIPBOARD=false HISTORY=false LAST=false CLEAR_HISTORY=false
DOCTOR=false
DRY_RUN=false PASS_THRU=false SELECT_ONLY=false COPY_URL=false OPEN_URL=false
REVERSE_URLS=false
DEBUG_REQUESTED=false
TYPE='' URL='' COOKIE_PATH_ARG='' COOKIE_BROWSER_ARG='' CONFIG_EXPORT='' CONFIG_IMPORT='' CONFIG_SET='' CONFIG_GET='' PLAYLIST_RESULTS_ARG='' DEBUG_LOG_PATH_ARG=''
POSITIONAL=()
MPV_EXTRA_ARGS=()
PLAY_TARGET_TITLES=()
PLAY_TARGET_TYPES=()

while (($#)); do
  case "$1" in
    -s|--search) SEARCH=true ;;
    --home) HOME_FEED=true ;;
    -p|--playlist) PLAYLIST=true ;;
    --channel-playlists|--channel-playlist) CHANNEL_PLAYLISTS=true ;;
    --playlist-results) play_require_option_value "$1" 'a positive integer' "${2-}"; PLAYLIST_RESULTS_ARG=$2; shift ;;
    --first|-fi) FIRST=true ;;
    -t|--type) play_require_option_value "$1" 'video, playlist, or channel' "${2-}"; TYPE=$2; shift ;;
    --clipboard) CLIPBOARD=true ;;
    --history) HISTORY=true ;;
    --last) LAST=true ;;
    --clear-history) CLEAR_HISTORY=true ;;
    --dry-run) DRY_RUN=true ;;
    --pass-thru) PASS_THRU=true ;;
    --debug) DEBUG_REQUESTED=true ;;
    --debug-log) play_require_option_value "$1" 'a log file path' "${2-}"; DEBUG_REQUESTED=true; DEBUG_LOG_PATH_ARG=$2; shift ;;
    --reverse) REVERSE_URLS=true ;;
    --select-only) SELECT_ONLY=true ;;
    --copy-url) COPY_URL=true ;;
    --open) OPEN_URL=true ;;
    --cookies|-c) play_require_option_value "$1" 'a cookie file path' "${2-}"; COOKIE_PATH_ARG=$2; shift ;;
    --cookies-from-browser) play_require_option_value "$1" 'a browser name' "${2-}"; COOKIE_BROWSER_ARG=$2; shift ;;
    --size|-sz) play_require_option_value "$1" 'pip, small, medium, or max' "${2-}"; SIZE_EFFECTIVE=$2; shift ;;
    -f|--format) play_require_option_value "$1" 'a format such as 480p, 720p, 1080p, best, or audio' "${2-}"; YTDL_FORMAT_EFFECTIVE=$2; shift ;;
    --audio-only|-a) AUDIO_ONLY_EFFECTIVE=true ;;
    --background|-b) BACKGROUND_EFFECTIVE=true ;;
    --loop|-l) LOOP_EFFECTIVE=true ;;
    --hwdec|-h) HARDWARE_ACCEL_EFFECTIVE=true ;;
    --reverse-playlist|-r) REVERSE_PLAYLIST_EFFECTIVE=true ;;
    --no-subtitles) NO_SUBTITLES_EFFECTIVE=true ;;
    --subtitle-language) play_require_option_value "$1" 'a subtitle language list' "${2-}"; SUBTITLE_LANGUAGE_EFFECTIVE=$2; shift ;;
    --mpv-arg) play_require_option_value "$1" 'an mpv argument' "${2-}" true; MPV_EXTRA_ARGS+=("$2"); shift ;;
    --config) play_open_config; exit ;;
    --config-path) play_ensure_config; play_config_path; exit ;;
    --config-export) play_require_option_value "$1" 'an export path' "${2-}"; CONFIG_EXPORT=$2; shift ;;
    --config-import) play_require_option_value "$1" 'an import path' "${2-}"; CONFIG_IMPORT=$2; shift ;;
    --install-bash-completion) play_install_bash_completion; exit ;;
    --set) play_require_option_value "$1" 'KEY=VALUE' "${2-}"; CONFIG_SET=$2; shift ;;
    --get) play_require_option_value "$1" 'KEY' "${2-}"; CONFIG_GET=$2; shift ;;
    --doctor) DOCTOR=true ;;
    --help|-help) play_usage; exit ;;
    --) shift; POSITIONAL+=("$@"); break ;;
    -*) printf 'Unknown option: %s\n' "$1" >&2; play_usage >&2; exit 2 ;;
    *) POSITIONAL+=("$1") ;;
  esac
  shift
done

if play_bool "$DEBUG_REQUESTED"; then
  play_debug_init "$DEBUG_LOG_PATH_ARG"
  play_debug_command 'argv' play "${PLAY_ORIGINAL_ARGS[@]}"
  play_debug_log "cwd: $PWD"
  play_debug_log "play root: $PLAY_ROOT"
  play_debug_log "bash: ${BASH_VERSION:-unknown}"
  play_debug_log "uname: $(uname -a 2>/dev/null || printf unknown)"
  play_debug_log "config path: $(play_config_path)"
  play_debug_log "state path: $(play_state_dir)"
fi

if [[ -n $CONFIG_EXPORT ]]; then play_export_config "$CONFIG_EXPORT"; exit; fi
if [[ -n $CONFIG_IMPORT ]]; then play_import_config "$CONFIG_IMPORT"; exit; fi
if [[ -n $CONFIG_SET ]]; then
  [[ $CONFIG_SET == *=* ]] || { play_error '--set requires KEY=VALUE.'; play_hint "$(play_option_hint --set)"; exit 2; }
  play_set_config_value "${CONFIG_SET%%=*}" "${CONFIG_SET#*=}"
  exit
fi
if play_bool "$DOCTOR"; then
  play_ensure_config
  if play_validate_config_file "$(play_config_path)" >/dev/null 2>&1; then
    # shellcheck source=/dev/null
    source "$(play_config_path)"
  fi
  play_doctor
  exit
fi

play_load_config
play_debug_log 'Config loaded.'

if [[ -n $CONFIG_GET ]]; then
  play_get_config_value "$CONFIG_GET"
  exit
fi

if [[ -n $PLAYLIST_RESULTS_ARG && ! $PLAYLIST_RESULTS_ARG =~ ^[1-9][0-9]*$ ]]; then
  play_error '--playlist-results requires a positive integer.'
  play_hint "$(play_option_hint --playlist-results)"
  exit 2
fi

if play_bool "$CLEAR_HISTORY"; then play_clear_history; exit; fi

SIZE_EFFECTIVE=${SIZE_EFFECTIVE:-${SIZE:-pip}}
YTDL_FORMAT_EFFECTIVE=${YTDL_FORMAT_EFFECTIVE:-${YTDL_FORMAT:-480p}}
AUDIO_ONLY_EFFECTIVE=${AUDIO_ONLY_EFFECTIVE:-${AUDIO_ONLY:-false}}
BACKGROUND_EFFECTIVE=${BACKGROUND_EFFECTIVE:-${BACKGROUND:-false}}
LOOP_EFFECTIVE=${LOOP_EFFECTIVE:-${LOOP:-false}}
HARDWARE_ACCEL_EFFECTIVE=${HARDWARE_ACCEL_EFFECTIVE:-${HARDWARE_ACCEL:-false}}
REVERSE_PLAYLIST_EFFECTIVE=${REVERSE_PLAYLIST_EFFECTIVE:-${REVERSE_PLAYLIST:-false}}
NO_SUBTITLES_EFFECTIVE=${NO_SUBTITLES_EFFECTIVE:-${NO_SUBTITLES:-false}}
SUBTITLE_LANGUAGE_EFFECTIVE=${SUBTITLE_LANGUAGE_EFFECTIVE:-${SUBTITLE_LANGUAGE:-en}}
COOKIE_PATH_EFFECTIVE=${COOKIE_PATH_ARG:-${COOKIE_PATH:-}}
COOKIE_BROWSER_EFFECTIVE=${COOKIE_BROWSER_ARG:-${COOKIE_BROWSER:-}}

play_validate_effective_settings
play_debug_log "mode: search=$SEARCH home=$HOME_FEED playlist=$PLAYLIST channel_playlists=$CHANNEL_PLAYLISTS first=$FIRST dry_run=$DRY_RUN select_only=$SELECT_ONLY copy_url=$COPY_URL open=$OPEN_URL"
play_debug_log "effective: player=${PLAYER:-mpv} size=$SIZE_EFFECTIVE format=$YTDL_FORMAT_EFFECTIVE fps=${YTDL_MAX_FPS:-30} audio=$AUDIO_ONLY_EFFECTIVE background=$BACKGROUND_EFFECTIVE loop=$LOOP_EFFECTIVE hwdec=$HARDWARE_ACCEL_EFFECTIVE subtitles_disabled=$NO_SUBTITLES_EFFECTIVE slang=$SUBTITLE_LANGUAGE_EFFECTIVE"

if [[ -n $COOKIE_PATH_ARG ]]; then
  if [[ ! -f $COOKIE_PATH_ARG ]]; then printf 'Cookie file not found: %s\n' "$COOKIE_PATH_ARG" >&2; exit 1; fi
  play_set_config_value COOKIE_PATH "$COOKIE_PATH_ARG"
  play_set_config_value COOKIE_BROWSER ""
fi

if [[ -n $COOKIE_BROWSER_ARG ]]; then
  play_set_config_value COOKIE_BROWSER "$COOKIE_BROWSER_ARG"
  play_set_config_value COOKIE_PATH ""
fi

if play_bool "$CLIPBOARD"; then URL=$(play_clipboard_get); fi
if play_bool "$LAST"; then
  last=$(play_last_history) || { printf 'Playback history is empty.\n' >&2; exit 1; }
  IFS=$'\t' read -r _ PLAY_HISTORY_TYPE PLAY_HISTORY_TITLE URL <<<"$last"
fi
if play_bool "$HISTORY"; then
  selected=$(play_select_history) || exit 1
  IFS=$'\t' read -r PLAY_HISTORY_TYPE PLAY_HISTORY_TITLE URL _ _ _ <<<"$selected"
fi

if [[ -z ${URL:-} && ${#POSITIONAL[@]} -gt 0 ]]; then
  URL=${POSITIONAL[*]}
fi
play_debug_log "input URL/query: ${URL:-<empty>}"

if [[ -z ${URL:-} && $HOME_FEED == false ]]; then
  play_usage
  exit
fi

if ! play_has "${PLAYER:-mpv}" && ! play_bool "$SELECT_ONLY" && ! play_bool "$COPY_URL" && ! play_bool "$OPEN_URL"; then
  printf 'Player not found: %s\n' "${PLAYER:-mpv}" >&2
  exit 1
fi

PLAY_HISTORY_TYPE=${PLAY_HISTORY_TYPE:-Direct}
PLAY_HISTORY_TITLE=${PLAY_HISTORY_TITLE:-$URL}

if play_bool "$SEARCH" || play_bool "$HOME_FEED"; then
  NORMALIZED_TYPE=
  if [[ -n $TYPE ]]; then NORMALIZED_TYPE=$(play_normalize_type "$TYPE") || play_invalid_value 'type' "$TYPE" 'video, playlist, or channel' 'Example: play -s "backlogs" --type channel'; fi
  play_has yt-dlp || { printf 'yt-dlp is required for search/home.\n' >&2; exit 1; }
  if play_bool "$CHANNEL_PLAYLISTS"; then
    if [[ -n $NORMALIZED_TYPE && $NORMALIZED_TYPE != Channel ]]; then play_error '--channel-playlists requires channel search results.'; play_hint 'Use --type channel or omit --type.'; exit 2; fi
    NORMALIZED_TYPE=Channel
  fi
  [[ $NORMALIZED_TYPE == Playlist ]] && PLAYLIST=true
  tmp=$(mktemp)
  play_register_cleanup_file "$tmp"
  result_batch=${MAX_RESULTS:-10}
  result_end=$result_batch
  play_section 'Search' >&2
  if play_bool "$HOME_FEED"; then
    play_detail 'Source' 'YouTube home feed' >&2
  else
    play_detail 'Query' "$URL" >&2
  fi
  play_detail 'Results' "$result_end" >&2
  if play_bool "$FIRST"; then
    play_detail 'Picker' 'first result' >&2
  else
    play_detail 'Picker' "${MENU_PROVIDER:-fzf}" >&2
  fi
  if [[ -n $COOKIE_PATH_EFFECTIVE ]]; then
    play_detail 'Cookies' "$COOKIE_PATH_EFFECTIVE" >&2
  elif [[ -n $COOKIE_BROWSER_EFFECTIVE ]]; then
    play_detail 'Cookies' "browser:$COOKIE_BROWSER_EFFECTIVE" >&2
  fi
  if [[ -n $NORMALIZED_TYPE ]]; then
    play_detail 'Type' "$NORMALIZED_TYPE" >&2
  elif play_bool "$PLAYLIST"; then
    play_detail 'Type' 'Playlist' >&2
  fi
  play_log step 'Fetching results.' >&2
  play_search_youtube "$URL" "$HOME_FEED" "$PLAYLIST" "$result_end" "$COOKIE_PATH_EFFECTIVE" "$NORMALIZED_TYPE" "$COOKIE_BROWSER_EFFECTIVE" >"$tmp"
  if [[ ! -s $tmp ]]; then play_unregister_cleanup_file "$tmp"; printf 'No results found.\n' >&2; rm -f "$tmp"; exit 1; fi
  if play_bool "$FIRST"; then
    selected=$(sed -n '1p' "$tmp")
  elif play_bool "$CHANNEL_PLAYLISTS" && selected=$(play_select_exact_channel_row "$(<"$tmp")" "$URL"); then
    play_detail 'Picker' 'exact channel match' >&2
    play_log ok 'Selected exact channel match.' >&2
  else
    state_file=$(mktemp)
    play_register_cleanup_file "$state_file"
    printf '%s\n' "$result_end" >"$state_file"
    more_cmd=$(play_make_more_results_command search "$tmp" "$state_file" "$result_batch" "$URL")
    selected=$(play_pick_result 'Search Results' "$tmp" true true "$more_cmd") || { play_unregister_cleanup_file "$tmp"; play_unregister_cleanup_file "$state_file"; rm -f "$tmp" "$state_file"; exit 1; }
    play_unregister_cleanup_file "$state_file"
    rm -f "$state_file"
  fi
  play_unregister_cleanup_file "$tmp"
  rm -f "$tmp"
  play_apply_selected_rows "$selected" || exit 1
  play_debug_log "selected: type=$PLAY_HISTORY_TYPE title=$PLAY_HISTORY_TITLE url=$PLAY_TARGET_URL"
  play_show_selected
  if play_bool "$CHANNEL_PLAYLISTS" && [[ $PLAY_HISTORY_TYPE != Channel ]]; then
    printf '%s\n' '--channel-playlists requires selecting a channel.' >&2
    exit 2
  fi
  if [[ $PLAY_HISTORY_TYPE == ChannelPlaylists ]] || { [[ $PLAY_HISTORY_TYPE == Channel ]] && play_bool "$CHANNEL_PLAYLISTS"; }; then
    play_pick_channel_playlists "$PLAY_TARGET_URL" "$PLAY_HISTORY_TITLE" "${PLAY_HISTORY_SOURCE:-$PLAY_HISTORY_TITLE}" || exit 1
    if play_bool "$REVERSE_URLS"; then
      play_reverse_targets
      REVERSE_URLS=false
    fi
    play_debug_log "selected channel playlist target: type=$PLAY_HISTORY_TYPE title=$PLAY_HISTORY_TITLE url=$PLAY_TARGET_URL count=${#PLAY_TARGET_URLS[@]}"
    play_show_selected
  fi
else
  if play_bool "$CHANNEL_PLAYLISTS"; then
    play_has yt-dlp || { printf 'yt-dlp is required for --channel-playlists.\n' >&2; exit 1; }
    if ! play_is_url "$URL"; then printf '%s\n' '--channel-playlists requires a channel URL, or use it with --search.' >&2; exit 2; fi
    play_pick_channel_playlists "$URL" "$URL" "$URL" || exit 1
    if play_bool "$REVERSE_URLS"; then
      play_reverse_targets
      REVERSE_URLS=false
    fi
    play_debug_log "selected channel playlist target: type=$PLAY_HISTORY_TYPE title=$PLAY_HISTORY_TITLE url=$PLAY_TARGET_URL count=${#PLAY_TARGET_URLS[@]}"
    play_show_selected
  else
    if ((${#POSITIONAL[@]} > 0)) && ! play_bool "$CLIPBOARD" && ! play_bool "$LAST" && ! play_bool "$HISTORY"; then
      PLAY_TARGET_URLS=("${POSITIONAL[@]}")
    else
      PLAY_TARGET_URLS=("$URL")
    fi
    PLAY_TARGET_TITLES=("${PLAY_TARGET_URLS[@]}")
    PLAY_TARGET_TYPES=()
    for target_url in "${PLAY_TARGET_URLS[@]}"; do PLAY_TARGET_TYPES+=(Direct); done
    if ((${#PLAY_TARGET_TITLES[@]} == 1)); then PLAY_TARGET_TITLES=("$PLAY_HISTORY_TITLE"); fi
    for target_url in "${PLAY_TARGET_URLS[@]}"; do
      if ! play_is_url "$target_url"; then printf 'Invalid URL. Use http:// or https://, or add --search.\n' >&2; exit 2; fi
    done
    PLAY_TARGET_URL=${PLAY_TARGET_URLS[0]}
    play_debug_log "direct target: url=$PLAY_TARGET_URL count=${#PLAY_TARGET_URLS[@]}"
  fi
fi

if play_bool "$REVERSE_URLS"; then
  play_reverse_targets
fi

play_expand_reversed_playlist_targets

for i in "${!PLAY_TARGET_URLS[@]}"; do
  PLAY_TARGET_URLS[i]=$(play_normalize_url "${PLAY_TARGET_URLS[i]}")
done
PLAY_TARGET_URL=${PLAY_TARGET_URLS[0]}

if play_bool "$SELECT_ONLY"; then printf '%s\t%s\t%s\n' "$PLAY_HISTORY_TYPE" "$PLAY_HISTORY_TITLE" "$PLAY_TARGET_URL"; exit; fi
if play_bool "$COPY_URL"; then play_clipboard_set "$PLAY_TARGET_URL"; printf 'Copied URL: %s\n' "$PLAY_TARGET_URL"; exit; fi
if play_bool "$OPEN_URL"; then play_has xdg-open || { printf 'xdg-open is required for --open.\n' >&2; exit 1; }; xdg-open "$PLAY_TARGET_URL"; exit; fi

play_build_mpv_args
play_apply_command_overrides
play_debug_log "target count: ${#PLAY_TARGET_URLS[@]}"
play_debug_command 'player command' "$PLAY_PLAYER" "${PLAY_MPV_ARGS[@]}" "${PLAY_TARGET_URLS[@]}"
play_launch
